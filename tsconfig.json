// tsconfig.json
{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES6",
        "allowJs": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strict": false,
        "moduleResolution": "node",
        "importHelpers": true
    },
    "include": ["**/*.ts"]
}
